# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/hr_management

# AI/LLM API Keys
# For Groq (Free tier available - Recommended)
GROQ_API_KEY=your_groq_api_key_here

# Alternatively, use OpenAI (uncomment if using OpenAI instead of Groq)
# OPENAI_API_KEY=your_openai_api_key_here

# Application Settings
APP_NAME="Agentic HR Management System"
DEBUG=True
SECRET_KEY=your-secret-key-here

# AI Agent Settings
# For Groq models (Free - Recommended)
RECRUITMENT_AGENT_MODEL=llama-3.3-70b-versatile
ONBOARDING_AGENT_MODEL=llama-3.3-70b-versatile

# For OpenAI models (Paid):
# RECRUITMENT_AGENT_MODEL=gpt-4-turbo-preview
# ONBOARDING_AGENT_MODEL=gpt-4-turbo-preview

AGENT_TEMPERATURE=0.7
AGENT_MAX_TOKENS=2000

# Production Settings (for deployment)
# Set DEBUG=False in production
# Generate SECRET_KEY with: python -c "import secrets; print(secrets.token_urlsafe(32))"
